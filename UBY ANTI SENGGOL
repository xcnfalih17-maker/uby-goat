-- -- 3. FITUR CHEAT (LOGIKA FIXED UNTUK OFF) -- --
_G.HitboxStatus = false
local function toggleYahayuk()
    _G.HitboxStatus = not _G.HitboxStatus
    local btn = main:FindFirstChild("YahayukBtn")
    if _G.HitboxStatus then
        if btn then btn.BackgroundColor3 = Color3.fromRGB(150, 230, 180) btn.Text = "YAHAYUK: ON" end
    else
        if btn then btn.BackgroundColor3 = Color3.fromRGB(255, 120, 180) btn.Text = "AUTO WALK YAHAYUK" end
        -- INI YANG PENTING: BALIKIN SIZE PAS OFF
        for _, v in pairs(game:GetService('Players'):GetPlayers()) do
            if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                pcall(function() v.Character.HumanoidRootPart.Size = Vector3.new(2,2,2) end)
            end
        end
    end
end

local btnYahayuk = Instance.new("TextButton", main)
