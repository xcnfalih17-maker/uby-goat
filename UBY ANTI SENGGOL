-- -- 3. LOGIC LISSPLOIT & SHORTCUT L -- --
_G.HitboxStatus = false
_G.HTrans = 0.7

local function toggleYahayuk()
    _G.HitboxStatus = not _G.HitboxStatus
    local btn = main:FindFirstChild("YahayukBtn")
    if _G.HitboxStatus then
        if btn then btn.BackgroundColor3 = Color3.fromRGB(0, 180, 0) end
    else
        if btn then btn.BackgroundColor3 = Color3.fromRGB(255, 115, 0) end
        for _, v in pairs(game:GetService('Players'):GetPlayers()) do
            if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                pcall(function() v.Character.HumanoidRootPart.Size = Vector3.new(2,2,2) v.Character.HumanoidRootPart.Transparency = 1 end)
            end
        end
    end
end

