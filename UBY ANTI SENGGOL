-- -- VARIABEL KONTROL -- --
_G.HitboxStatus = false
_G.HSize = 10
_G.HTrans = 0.7

-- FUNGSI RESET TOTAL
local function resetHitbox()
    for _, v in pairs(game:GetService('Players'):GetPlayers()) do
        if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            pcall(function()
                local hrp = v.Character.HumanoidRootPart
                hrp.Size = Vector3.new(2, 2, 2)
                hrp.Transparency = 1
                hrp.BrickColor = BrickColor.new("Medium stone grey")
                hrp.Material = Enum.Material.Plastic
                hrp.CanCollide = true
            end)
        end
    end
end

-- TOMBOL YAHAYUK (SIZE)
local btnSize = Instance.new("TextButton", main)
btnSize.Size = UDim2.new(0, 180, 0, 45)
btnSize.Position = UDim2.new(0.5, -90, 0.5, 0)
btnSize.BackgroundColor3 = Color3.fromRGB(255, 115, 0)
btnSize.Text = "AUTO WALK YAHAYUK: OFF"
btnSize.TextColor3 = Color3.new(1, 1, 1)
btnSize.Font = Enum.Font.GothamBold
btnSize.TextSize = 10
btnSize.ZIndex = 7
Instance.new("UICorner", btnSize).CornerRadius = UDim.new(0, 10)

btnSize.MouseButton1Click:Connect(function()
    _G.HitboxStatus = not _G.HitboxStatus
    if _G.HitboxStatus then
        btnSize.Text = "AUTO WALK YAHAYUK: ON"
        btnSize.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
    else
        btnSize.Text = "AUTO WALK YAHAYUK: OFF"
        btnSize.BackgroundColor3 = Color3.fromRGB(255, 115, 0)
        resetHitbox()
    end
end)

