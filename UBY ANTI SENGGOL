userInputService.InputBegan:Connect(function(input, gp) 
    if gp then return end
    if input.KeyCode == Enum.KeyCode.K then screenGui.Enabled = not screenGui.Enabled end
    if input.KeyCode == Enum.KeyCode.L then toggleYahayuk() end
end)

