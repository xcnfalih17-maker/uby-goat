local function toggleYahayuk()
    _G.HitboxStatus = not _G.HitboxStatus
    if _G.HitboxStatus then
        btnYahayuk.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
    else
        btnYahayuk.BackgroundColor3 = Color3.fromRGB(255, 115, 0)
        resetHitbox()
    end
end

