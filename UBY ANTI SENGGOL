-- -- 3. LOGIC FITUR (ANTI-KOTAK/BOX) -- --
_G.HitboxStatus = false

local function toggleYahayuk()
    _G.HitboxStatus = not _G.HitboxStatus
    local btn = main:FindFirstChild("YahayukBtn")
    
    if _G.HitboxStatus then
        if btn then 
            btn.BackgroundColor3 = Color3.fromRGB(150, 230, 180)
            btn.Text = "YAHAYUK: ON"
        end
    else
        if btn then 
            btn.BackgroundColor3 = Color3.fromRGB(255, 120, 180)
            btn.Text = "AUTO WALK YAHAYUK" 
        end
        -- RESET TOTAL PAS OFF
        for _, v in pairs(game.Players:GetPlayers()) do
            if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                pcall(function() 
                    local hrp = v.Character.HumanoidRootPart
                    hrp.Size = Vector3.new(2,2,2) 
                    hrp.Transparency = 0
                    -- Hapus semua efek visual (kotak) yang nempel
                    for _, effect in pairs(hrp:GetChildren()) do
                        if effect:IsA("SelectionBox") or effect:IsA("BoxHandleAdornment") or effect:IsA("LineHandleAdornment") then
                            effect:Destroy()
                        end
                    end
                end)
            end
        end
    end
end

