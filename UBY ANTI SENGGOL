-- -- TOMBOL MENIPU (BELUT MODE) -- --
local exitBtn = Instance.new("TextButton", bg)
exitBtn.Size = UDim2.new(0, 180, 0, 45)
exitBtn.Position = UDim2.new(0, 20, 1, -65) -- Start Kiri Bawah
exitBtn.BackgroundColor3 = Color3.fromRGB(255, 120, 180)
