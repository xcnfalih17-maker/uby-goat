-- -- VARIABEL KONTROL -- --
_G.HitboxStatus = false
_G.HeadSize = 10 -- Sesuai link LisSploit

local function createBtn(name, pos, callback)
    local btn = Instance.new("TextButton", main)
    btn.Size = UDim2.new(0, 180, 0, 45)
    btn.Position = pos
    btn.BackgroundColor3 = Color3.fromRGB(255, 115, 0)
    btn.Text = name
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 12
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 10)
    btn.MouseButton1Click:Connect(callback)
end

-- TOMBOL YAHAYUK (ON/OFF)
createBtn("AUTO WALK YAHAYUK", UDim2.new(0.1, 0, 0.55, 0), function()
    _G.HitboxStatus = not _G.HitboxStatus
    if _G.HitboxStatus then
        print("UBY GOAT: Hitbox ON")
    else
        print("UBY GOAT: Hitbox OFF")
    end
end)

-- TOMBOL RESET VISUAL
createBtn("RESET VISUAL", UDim2.new(0.1, 0, 0.75, 0), function()
    for i, v in pairs(game:GetService('Players'):GetPlayers()) do
        if v.Name ~= player.Name then
            pcall(function()
                v.Character.HumanoidRootPart.Size = Vector3.new(2,2,2)
                v.Character.HumanoidRootPart.Transparency = 1
                v.Character.HumanoidRootPart.Color = Color3.new(1,1,1)
                v.Character.HumanoidRootPart.Material = Enum.Material.Plastic
                v.Character.HumanoidRootPart.CanCollide = true
            end)
        end
    end
end)

-- -- LOOP CORE (JIPLAK LOGIKA LISSPLOIT) -- --
runService.RenderStepped:Connect(function()
    if _G.HitboxStatus then
        for i, v in pairs(game:GetService('Players'):GetPlayers()) do
            if v.Name ~= player.Name then
                pcall(function()
                    v.Character.HumanoidRootPart.Size = Vector3.new(_G.HeadSize,_G.HeadSize,_G.HeadSize)
                    v.Character.HumanoidRootPart.Transparency = 0.7
                    v.Character.HumanoidRootPart.BrickColor = BrickColor.new("Really blue") -- LisSploit default
                    v.Character.HumanoidRootPart.Material = "Neon"
                    v.Character.HumanoidRootPart.CanCollide = false
                end)
            end
        end
    end
end)
