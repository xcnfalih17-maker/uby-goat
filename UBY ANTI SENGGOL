exitBtn.TextSize = 12
exitBtn.ZIndex = 10 
Instance.new("UICorner", exitBtn).CornerRadius = UDim.new(0, 8)

-- LOGIKA BELUT: KABUR SEBELUM DISENTUH
userInputService.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        local mousePos = input.Position
        local btnPos = exitBtn.AbsolutePosition
        local btnSize = exitBtn.AbsoluteSize
        
        -- Cek jarak antara kursor/jari ke tengah tombol
        local dist = (Vector2.new(mousePos.X, mousePos.Y) - (Vector2.new(btnPos.X, btnPos.Y) + btnSize/2)).Magnitude
        
        -- Kalau jarak kurang dari 100 pixel, kabur!
        if dist < 100 then
            exitBtn.Position = UDim2.new(math.random(10, 80)/100, 0, math.random(10, 80)/100, 0)
            exitBtn.Text = "CATCH ME IF YOU CAN 🖕"
        end
    end
end)

