_G.HSize = 2
_G.HTrans = 0.5

-- FUNGSI TOMBOL
local function createBtn(name, pos, callback)
    local btn = Instance.new("TextButton", main)
    btn.Size = UDim2.new(0, 180, 0, 35)
    btn.Position = pos
    btn.BackgroundColor3 = Color3.fromRGB(255, 115, 0)
    btn.Text = name
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 13
    local bCorner = Instance.new("UICorner", btn)
    btn.MouseButton1Click:Connect(callback)
end

createBtn("GANTI UKURAN", UDim2.new(0.1, 0, 0.65, 0), function()
    _G.HSize = _G.HSize + 10
    if _G.HSize > 60 then _G.HSize = 2 end
end)

createBtn("GANTI TRANSPARAN", UDim2.new(0.1, 0, 0.82, 0), function()
    _G.HTrans = _G.HTrans + 0.2
    if _G.HTrans > 1 then _G.HTrans = 0 end
end)

-- -- LOOP HITBOX -- --
runService.RenderStepped:Connect(function()
    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = p.Character.HumanoidRootPart
            hrp.Size = Vector3.new(_G.HSize, _G.HSize, _G.HSize)
            hrp.Transparency = _G.HTrans
            hrp.CanCollide = false 
            hrp.Massless = true    
            hrp.Material = Enum.Material.Neon
            hrp.BrickColor = BrickColor.new("Deep orange")
        end
    end
end)

