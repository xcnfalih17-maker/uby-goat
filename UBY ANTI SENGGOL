-- -- 3. LOGIC HITBOX (ON/OFF) -- --
_G.HitboxStatus = false

local function toggleHitbox()
    _G.HitboxStatus = not _G.HitboxStatus
    local btn = main:FindFirstChild("TogBtn")
    
    if _G.HitboxStatus then
        if btn then btn.Text = "YAHAYUK: ON" btn.BackgroundColor3 = Color3.fromRGB(150, 230, 180) end
    else
        if btn then btn.Text = "AUTO WALK YAHAYUK" btn.BackgroundColor3 = Color3.fromRGB(255, 120, 180) end
        -- RESET SEMUA JADI NORMAL
        for _, v in pairs(game.Players:GetPlayers()) do
            if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                pcall(function()
                    v.Character.HumanoidRootPart.Size = Vector3.new(2, 2, 2)
                    v.Character.HumanoidRootPart.Transparency = 0
                end)
            end
        end
    end
end

